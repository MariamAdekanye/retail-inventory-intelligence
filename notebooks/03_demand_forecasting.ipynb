    "# ── Step 6: Write forecast to Gold Delta table ────────────────────────\n",
    "\n",
    "# Select only the columns Power BI needs\n",
    "forecast_output = forecast[[\"ds\", \"yhat\", \"yhat_lower\", \"yhat_upper\"]].copy()\n",
    "\n",
    "# Add store and product context so Power BI knows which combination\n",
    "# this forecast belongs to\n",
    "forecast_output[\"store_nbr\"] = 1\n",
    "forecast_output[\"product_family\"] = \"GROCERY I\"\n",
    "\n",
    "# Rename ds back to date for consistency with other Gold tables\n",
    "forecast_output = forecast_output.rename(columns={\"ds\": \"date\"})\n",
    "\n",
    "# Convert back to Spark DataFrame for writing to Delta\n",
    "forecast_spark = spark.createDataFrame(forecast_output)\n",
    "\n",
    "# Write to Gold layer\n",
    "forecast_spark.write.format(\"delta\").mode(\"overwrite\").save(\"Tables/gold_forecast\")\n",
    "\n",
    "print(\"Forecast written to Tables/gold_forecast successfully\")\n",
    "\n",
    "# Verify it is there\n",
    "verification = spark.read.format(\"delta\").load(\"Tables/gold_forecast\")\n",
    "print(f\"Rows in gold_forecast: {verification.count()}\")\n",
    "print(f\"Columns: {verification.columns}\")\n",
    "\n",
    "\n"
   ]
