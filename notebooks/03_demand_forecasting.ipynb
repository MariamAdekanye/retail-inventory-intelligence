    "# ── Step 8: Combine all forecasts and write to Gold layer ─────────────\n",
    "import pandas as pd\n",
    "\n",
    "# Stack all forecast DataFrames into one\n",
    "combined_forecasts = pd.concat(all_forecasts, ignore_index=True)\n",
    "print(f\"Total forecast rows: {len(combined_forecasts)}\")\n",
    "\n",
    "# Convert to Spark and write to Gold layer\n",
    "# mode overwrite replaces the single-store test run from earlier\n",
    "combined_spark = spark.createDataFrame(combined_forecasts)\n",
    "combined_spark.write.format(\"delta\").mode(\"overwrite\").save(\"Tables/gold_forecast\")\n",
    "\n",
    "print(\"Combined forecast written to Tables/gold_forecast\")\n",
    "\n",
    "# Final verification\n",
    "final_check = spark.read.format(\"delta\").load(\"Tables/gold_forecast\")\n",
    "print(f\"Final row count: {final_check.count()}\")\n",
    "final_check.groupBy(\"store_nbr\", \"product_family\").count().show()"
