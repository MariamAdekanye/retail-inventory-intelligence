    "# ── Step 2: Rename columns to what Prophet requires ──────────────────\n",
    "# Prophet is strict — columns MUST be called ds and y\n",
    "df = df.rename(columns={\"date\": \"ds\", \"sales\": \"y\"})\n",
    "\n",
    "# Remove any rows where y is null — Prophet cannot handle nulls\n",
    "df = df.dropna(subset=[\"y\"])\n",
    "\n",
    "# Confirm the rename worked\n",
    "print(df.columns.tolist()) \n",
    "print(f\"Null values remaining: {df['y'].isnull().sum()}\")  "
   ]
