    "stores_to_forecast = [1, 2, 3]\n",
    "families_to_forecast = [\n",
    "    \"GROCERY I\", \n",
    "    \"BEVERAGES\", \n",
    "    \"PRODUCE\", \n",
    "    \"CLEANING\", \n",
    "    \"DAIRY\"\n",
    "]\n",
    "\n",
    "all_forecasts = []\n",
    "\n",
    "for store in stores_to_forecast:\n",
    "    for family in families_to_forecast:\n",
    "        \n",
    "        print(f\"Fitting model: Store {store} — {family}\")\n",
    "        \n",
    "        df_combo = gold_sales \\\n",
    "            .filter(\n",
    "                (col(\"store_nbr\") == store) & \n",
    "                (col(\"product_family\") == family)\n",
    "            ) \\\n",
    "            .select(\"date\", \"sales\") \\\n",
    "            .toPandas()\n",
    "        \n",
    "        if len(df_combo) < 30:\n",
    "            print(f\"  Skipping — not enough data ({len(df_combo)} rows)\")\n",
    "            continue\n",
    "        \n",
    "        df_combo = df_combo.rename(columns={\"date\": \"ds\", \"sales\": \"y\"})\n",
    "        df_combo = df_combo.dropna(subset=[\"y\"])\n",
    "        \n",
    "        model = Prophet(\n",
    "            yearly_seasonality=True,\n",
    "            weekly_seasonality=True,\n",
    "            daily_seasonality=False\n",
    "        )\n",
    "        model.fit(df_combo)\n",
    "        \n",
    "        future = model.make_future_dataframe(periods=28)\n",
    "        forecast = model.predict(future)\n",
    "        \n",
    "        forecast_output = forecast[[\"ds\", \"yhat\", \"yhat_lower\", \"yhat_upper\"]].copy()\n",
    "        forecast_output[\"store_nbr\"] = store\n",
    "        forecast_output[\"product_family\"] = family\n",
    "        forecast_output = forecast_output.rename(columns={\"ds\": \"date\"})\n",
    "        \n",
    "        all_forecasts.append(forecast_output)\n",
    "        print(f\"  Done — {len(forecast_output)} rows forecast\")\n",
    "\n",
    "print(f\"\\nAll models complete. Total combinations: {len(all_forecasts)}\")"
   ]
  },
