    "# ── Step 3: Fit the Prophet model ────────────────────────────────────\n",
    "model = Prophet(\n",
    "    yearly_seasonality=True,   # learns December peaks, January dips etc\n",
    "    weekly_seasonality=True,   # learns Saturday vs Monday patterns\n",
    "    daily_seasonality=False    # not needed for daily data\n",
    ")\n",
    "\n",
    "model.fit(df)\n",
    "\n",
    "print(\"Model fitted successfully\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "24c515d8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Step 4: Create future dates and generate forecast ─────────────────\n",
    "\n",
    "# make_future_dataframe creates a DataFrame with ALL historical dates\n",
    "# plus 28 new future dates added at the end\n",
    "future = model.make_future_dataframe(periods=28)\n",
    "\n",
    "print(f\"Future dataframe rows: {len(future)}\")\n",
    "print(f\"Last 5 dates (includes the 28 new future dates):\")\n",
    "print(future.tail())"
   ]
  },
