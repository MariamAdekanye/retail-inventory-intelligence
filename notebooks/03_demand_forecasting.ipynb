    "# ── Step 1: Load and join Silver tables directly in PySpark ──────────\n",
    "# gold_daily_sales is a SQL view — Spark cannot read views directly\n",
    "# We replicate the join logic here instead\n",
    "\n",
    "from pyspark.sql.functions import col, coalesce, lit\n",
    "\n",
    "# Load Silver tables\n",
    "Silver_sales = spark.read.format(\"delta\").load(\"Tables/Silver_sales\")\n",
    "silver_store = spark.read.format(\"delta\").load(\"Tables/silver_store\")\n",
    "silver_holidays = spark.read.format(\"delta\").load(\"Tables/silver_holidays\")\n",
    "silver_oil = spark.read.format(\"delta\").load(\"Tables/silver_oil\")\n",
    "\n",
    "# Replicate the gold_daily_sales join logic\n",
    "gold_sales = Silver_sales \\\n",
    "    .join(silver_store, on=\"store_nbr\", how=\"left\") \\\n",
    "    .join(silver_holidays, on=\"date\", how=\"left\") \\\n",
    "    .join(silver_oil, on=\"date\", how=\"left\") \\\n",
    "    .withColumn(\"is_holiday\", coalesce(col(\"is_holiday\"), lit(0))) \\\n",
    "    .select(\n",
    "        \"date\",\n",
    "        \"store_nbr\",\n",
    "        \"family\",\n",
    "        \"sales\",\n",
    "        \"onpromotion\",\n",
    "        \"is_holiday\",\n",
    "        \"oil_price\"\n",
    "    )\n",
    "\n",
    "\n",
    "\n",
    "# Now filter to Store 1, GROCERY I\n",
    "df = gold_sales \\\n",
    "    .filter(\n",
    "        (col(\"store_nbr\") == 1) &\n",
    "        (col(\"family\") == \"GROCERY I\")\n",
    "    ) \\\n",
    "    .select(\"date\", \"sales\") \\\n",
    "    .toPandas()\n",
    "\n",
    "print(f\"Rows loaded: {len(df)}\")\n",
    "print(f\"Date range: {df['date'].min()} to {df['date'].max()}\")\n",
    "print(df.head())"
   ]
  },
